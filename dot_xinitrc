if [ -d /etc/X11/xinit/xinitrc.d ]; then
    for f in /etc/X11/xinit/xinitrc.d/*; do
	[ -x "$f" ] && . "$f"
    done
    unset f
fi

export CM_LAUNCHER=rofi

exec xsetroot -solid "#202020" &

exec dunst &

exec clipmenud &

setxkbmap -option compose:ralt

setxkbmap -option ctrl:nocaps

xcape -e 'Caps_Lock=Escape'

exec dwm
