{
    "layer": "top",

    "position": "top",

    "height": 30,

    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],

    // "modules-center": [
        // "sway/window"
    // ],

    "modules-right": [
        "network",
        "pulseaudio",
        "memory",
        "cpu",
        // "temperature",
        "battery",
        "tray",
        "clock#date",
        "clock#time"
    ],

    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "яГз  {icon}  {capacity}%",
        "format-discharging": "{icon}  {capacity}%",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА" ,
        ],
        "tooltip": true
    },

    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "tooltip": false
    },

    "clock#date": {
      "interval": 10,
      "format": "яБ│  {:%e %b %Y}", // Icon: calendar-alt
      "tooltip-format": "{:%e %B %Y}"
    },

    "cpu": {
        "interval": 5,
        "format": "яЛЫ  {usage}% ({load})",
        "states": {
          "warning": 70,
          "critical": 90
        }
    },

    "custom/keyboard-layout": {
      "exec": "swaymsg -t get_inputs | grep -m1 'xkb_active_layout_name' | cut -d '\"' -f4",
      "interval": 30,
      "format": "яДЬ  {}", // Icon: keyboard
      "signal": 1, // SIGHUP
      "tooltip": false
    },

    "memory": {
        "interval": 5,
        "format": "яФ╕  {}%", // Icon: memory
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 5,
        "format-wifi": "яЗл  {essid} ({signalStrength}%)", // Icon: wifi
        "format-ethernet": "яЮЦ  {ifname}: {ipaddr}/{cidr}", // Icon: ethernet
        "format-disconnected": "тЪа  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">яМЮ  {}</span>", // Icon: expand-arrows-alt
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 120
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "persistent_workspaces": {
            "1: WWW ": [],
            "2: TERM ": [], 
            "3: DEV ": [],
            "4: CHAT ": []
        },
        "format-icons": {
            "1: WWW ": " www ",
            "2: TERM ": " term ",
            "3: DEV ": " dev",
            "4: CHAT ": " chat ",
            "5: GFX ": " gfx ",
            "6: MEDIA ": " media ",
            "urgent": " яБк ",
            "focused": " яЖТ ",
            "default": " яДС "
        }
    },

    "pulseaudio": {
        //"scroll-step": 1,
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}  {volume}%яКФ",
        "format-muted": "яАж",
        "format-icons": {
            "headphones": "яАе",
            "handsfree": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },

    "temperature": {
      "critical-threshold": 80,
      "interval": 5,
      "format": "{icon}  {temperatureC}┬░C",
      "format-icons": [
          "яЛЛ",
          "яЛК",
          "яЛЙ",
          "яЛИ",
          "яЛИ" ,
      ],
      "tooltip": true
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10
    }

}
